# 腾讯云API配置
TENCENT_SECRET_ID=your_secret_id_here
TENCENT_SECRET_KEY=your_secret_key_here
HUNYUAN_ENDPOINT=hunyuan.tencentcloudapi.com
HUNYUAN_REGION=ap-guangzhou

# 腾讯元器智能体配置（已配置）
YUANQI_AGENT_ID=2038933396066927680
YUANQI_API_KEY=utXTbDpy1sCgupaMfCVN7PhBkQfDRgL1

# 腾讯元器API配置（如果使用元器API）
# 注意：如果使用元器模型，可能需要将 HUNYUAN_MODEL 设置为相应的模型ID
YUANQI_API_BASE_URL=https://open.hunyuan.tencent.com/openapi/v1/agent/chat/completions

# 数据库配置
DATABASE_URL=sqlite:///./tactical_vision.db

# CORS配置（前端开发服务器地址）
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# 应用配置
DEBUG=true
LOG_LEVEL=INFO

# AI配置
# 模型名称：hunyuan-standard（混元标准版）、hunyuan-pro（混元高级版）
# 或腾讯元器模型ID
HUNYUAN_MODEL=hunyuan-standard
MAX_RETRIES=3
REQUEST_TIMEOUT=30
# 模拟模式（当API调用失败时使用模拟数据，用于测试）
SIMULATE_MODE=false
